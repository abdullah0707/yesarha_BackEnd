{
  "python.analysis.exclude": [
    ".venv/**",
    "**/site-packages/**",
    "**/__pycache__/**"
  ],
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/site-packages/**": true,
    "**/__pycache__/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/*.pyc": true
  },
  "python.defaultInterpreterPath": ".venv/Scripts/python.exe"
}
